[Unit]
Description=Bridge Updater Service
After=network-online.target
Wants=network-online.target
After=tor@default.service

[Service]
Type=oneshot
User=root
ExecStart=/usr/local/bin/bridge_updater update -c /etc/brupd_conf.json -l error