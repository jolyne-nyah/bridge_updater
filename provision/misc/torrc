
#jolyne-nyah's custom tor configuration for bridge_updater's vagrant environment.

UseBridges 1
ClientTransportPlugin obfs4 exec /usr/bin/obfs4proxy

SocksPort 0.0.0.0:9050

ControlPort 9051
CookieAuthentication 1

%include /etc/tor/torrc.d/

#ipv6 support. comment lines below if you don't need it or have issues with it
#NOTICE: ygg bridges are only available in ipv6.
SocksPort [::]:9050
ClientUseIPv6 1

#yggdrasil bridges support. DO NOT COMMENT/UNCOMMENT THIS ON YOUR OWN!
#If you want to turn on/off the yggdrasil bridges, 
#enter the vagrant vm and run the command:
#ygg on / ygg off 
#%include /etc/tor/yggbr.conf

#trusted nodes
ExitNodes {us},{de},{nl},{ch},{fr}
StrictNodes 1

#qf for streaming services
MaxCircuitDirtiness 3600